
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String      @id @default(uuid())
  username       String      @unique
  debatesAsUser1 DebateSession[] @relation("User1")
  debatesAsUser2 DebateSession[] @relation("User2")
  votes          Vote[]
  topicsCreated  Topic[]
}

model Topic {
  id          String          @id @default(uuid())
  title       String
  description String?
  creatorId   String
  creator     User            @relation(fields: [creatorId], references: [id])
  sessions    DebateSession[]
  createdAt   DateTime        @default(now())
}

model DebateSession {
  id          String   @id @default(uuid())
  topicId     String
  topic       Topic    @relation(fields: [topicId], references: [id])
  
  user1Id     String
  user1       User     @relation("User1", fields: [user1Id], references: [id])
  
  user2Id     String
  user2       User     @relation("User2", fields: [user2Id], references: [id])

  status      DebateStatus @default(WAITING)
  rounds      Round[]
  votes       Vote[]
  aiReport    AIReport?
  createdAt   DateTime @default(now())
}

model Round {
  id               String        @id @default(uuid())
  debateSessionId  String
  debateSession    DebateSession @relation(fields: [debateSessionId], references: [id])
  speakerId        String
  content          String        @db.Text
  roundNumber      Int
  durationSeconds  Int
  createdAt        DateTime      @default(now())
}

model Vote {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  debateSessionId  String
  debateSession    DebateSession @relation(fields: [debateSessionId], references: [id])
  votedForUserId   String        // The ID of the debater they think argued better
  createdAt        DateTime      @default(now())
}

model AIReport {
  id               String        @id @default(uuid())
  debateSessionId  String        @unique
  debateSession    DebateSession @relation(fields: [debateSessionId], references: [id])
  analysisJson     Json          // Stores fallacies, scores, and rhetorical moves
  overallWinnerId  String?
}

enum DebateStatus {
  WAITING
  IN_PROGRESS
  VOTING
  FINISHED
}